{
  "name": "image-generator",
  "version": "1.0.0",
  "description": "AI-powered product image generation using fal.ai's **Nano Banana 2 Edit** model (Google Gemini 3.1 Flash Image). Transforms fabric swatch cards into professional lifestyle product images, hero banners, and collection showcases.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "baml:generate": "baml-cli generate --from src/baml_src",
    "generate": "tsx src/generate.ts",
    "lifestyle": "tsx src/generate.ts lifestyle",
    "texture": "tsx src/generate.ts texture",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@boundaryml/baml": "^0.220.0",
    "@fal-ai/client": "^1.9.4",
    "@resvg/resvg-js": "^2.6.2",
    "dotenv": "^17.3.1",
    "satori": "^0.25.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
