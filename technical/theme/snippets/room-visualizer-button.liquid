{% if product.tags contains 'odanda-gor' %}
  <div style="padding: 8px 0 16px;">
    <button
      type="button"
      id="odanda-gor-btn"
      style="display:block;width:100%;padding:14px 24px;background:#1B2A4A;color:#ffffff;border:none;border-radius:4px;font-size:1rem;font-family:inherit;font-weight:600;cursor:pointer;letter-spacing:0.02em;"
    >Odanda Gör</button>
  </div>
  <script src="{{ 'room-visualizer.js' | asset_url }}"></script>
  <script>
    (function () {
      var variantSkus = {
        {%- for variant in product.variants -%}
          "{{ variant.id }}": {{ variant.sku | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      };

      function getCurrentSku() {
        var input = document.querySelector('form[data-type="add-to-cart-form"] input[name="id"]');
        var id = input ? input.value : new URLSearchParams(location.search).get('variant');
        return id ? (variantSkus[id] || '') : '';
      }

      var btn = document.getElementById('odanda-gor-btn');
      if (btn) {
        btn.addEventListener('click', function () {
          initRoomVisualizer({
            productId: 'gid://shopify/Product/{{ product.id }}',
            productHandle: '{{ product.handle }}',
            productTitle: {{ product.title | json }},
            productType: {{ product.type | json }},
            productColor: {{ product.metafields.curtain.color | default: '' | json }},
            productImageUrl: {{ product.featured_image | image_url: width: 400 | json }},
            productSku: getCurrentSku(),
            apiUrl: 'https://visualizer.inanctekstil.store/api/visualize'
          });
        });
      }
    })();
  </script>
{% endif %}
